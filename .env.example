# ComposeCockpit Configuration
# Copy this to .env and fill in values

# Server
HOST=0.0.0.0
PORT=8080
READ_TIMEOUT=30s
WRITE_TIMEOUT=120s
SHUTDOWN_TIMEOUT=30s

# Database
DATABASE_URL=postgres://cockpit:cockpit_secret@localhost:5432/cockpit?sslmode=disable
DB_MAX_CONNS=20
DB_MIN_CONNS=5

# Docker
DOCKER_HOST=unix:///var/run/docker.sock
DOCKER_API_VERSION=1.44

# Authentication
JWT_SECRET=change-me-to-a-random-string-at-least-32-chars
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=168h
BCRYPT_COST=12

# Discovery
COMPOSE_ROOT=/data/projects
SCAN_INTERVAL=5m
SCAN_MAX_DEPTH=10

# Telemetry
LOG_LEVEL=info
OTEL_SERVICE_NAME=compose-cockpit
ENABLE_TRACING=false
OTEL_EXPORTER_OTLP_ENDPOINT=
